# Copy to .env.local and fill in real values
# FGA (Auth0 FGA store credentials)
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=
FGA_MODEL_ID=
FGA_API_TOKEN_ISSUER=auth.fga.dev
FGA_API_AUDIENCE=https://api.us1.fga.dev/
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=

# Auth0 tenant
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://astracredit.demo/mcp

# Claude.ai MCP OAuth client (pre-registered in Auth0)
MCP_CLIENT_ID=
MCP_CLIENT_SECRET=

# CIBA client (server-side, used to initiate backchannel auth)
CIBA_CLIENT_ID=
CIBA_CLIENT_SECRET=

# Management API client (for Guardian enrollment checks)
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Demo user — Sarah's Auth0 user_id (auth0|xxxx), set after creating the user
SARAH_USER_ID=

# Public base URL for this server (ngrok URL when running locally)
NEXT_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io
