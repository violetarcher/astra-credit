# Copy to .env.local and fill in real values

# ── FGA (Auth0 FGA store credentials) ────────────────────────────────────────
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=
FGA_MODEL_ID=
FGA_API_TOKEN_ISSUER=auth.fga.dev
FGA_API_AUDIENCE=https://api.us1.fga.dev/
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=

# ── Auth0 tenant (shared) ─────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com

# ── MCP server — used to initiate CIBA requests ───────────────────────────────
AUTH0_AUDIENCE=https://your-ngrok-url.ngrok-free.dev/
CIBA_CLIENT_ID=
CIBA_CLIENT_SECRET=

# ── Management API — used for Guardian enrollment checks ──────────────────────
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# ── Demo panel auth (Regular Web Application in Auth0) ───────────────────────
# Create a Regular Web Application in Auth0 Dashboard.
# Allowed Callback URLs: https://your-domain/auth/callback
# Allowed Logout URLs:   https://your-domain
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: openssl rand -hex 32
AUTH0_SECRET=

# ── Public base URL (ngrok URL when running locally) ─────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.dev/
# Optional — Auth0 SDK uses this for callback/logout URL construction.
# Defaults to inferring from the incoming request host if omitted.
# APP_BASE_URL=https://your-ngrok-url.ngrok-free.dev
